# Copy this file to .env.local and fill in your real values.
# cp .env.local.example .env.local

# Clerk Authentication — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/

# OpenRouter AI — https://openrouter.ai
OPENROUTER_API_KEY=

# Supabase PostgreSQL (Drizzle ORM) — https://supabase.com
DATABASE_URL=

# Google OAuth Setup (Gmail read-only) — https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_ENCRYPTION_KEY= # Random 32-character string for AES-256 token encryption
NEXT_PUBLIC_APP_URL=http://localhost:3000